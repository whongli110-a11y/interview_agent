APP_ENV=local

# ── 数据存储路径 ─────────────────────────────────────────────────────────────
# 留空则使用基于 backend/ 目录的默认绝对路径（推荐）
DATABASE_PATH=
UPLOAD_DIR=
PARSED_DIR=
CHROMA_DB_PATH=          # ChromaDB 持久化目录（替换原 JSON 向量文件）
CHECKPOINT_DB_PATH=

# ── LLM 配置 ─────────────────────────────────────────────────────────────────
LLM_PROVIDER=mock          # mock（默认，无需 API Key）或 openai_compatible
LLM_BASE_URL=              # 例如：https://api.openai.com/v1 或 Ollama 地址
LLM_API_KEY=
LLM_MODEL=gpt-4o           # 或 deepseek-chat、qwen-turbo 等

# ── Embedding 配置 ────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=mock              # mock | openai_compatible（语义向量）
EMBEDDING_DIMENSION=128              # 仅 mock 模式使用
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=                  # 留空则使用 LLM_BASE_URL
EMBEDDING_API_KEY=                   # 留空则使用 LLM_API_KEY

# ── LangSmith 可观测性 ──────────────────────────────────────────────────────────
# 开启后可在 https://smith.langchain.com 查看每个节点运行详情和检索精度
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=ls__xxxxxxxx          # 从 LangSmith 控制台获取
# LANGSMITH_PROJECT=interviewer-agent     # 在 LangSmith 中显示的项目名称
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── 其他 ──────────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=10
DEFAULT_USER_ID=default
CORS_ALLOWED_ORIGINS=["https://your-frontend.example.com"]
